# VITAHUB Cron Jobs
# Close XP weekly periods (Friday 18:05 CLT)
5 18 * * 5 root cd /app/apps/api && node dist/cron/close-xp-period.js
# Create monthly cycles (1st of month at 02:00)
0 2 1 * * root cd /app/apps/api && node dist/cron/create-monthly-cycles.js
# Detect stale pieces (every 2 hours)
0 */2 * * * root cd /app/apps/api && node dist/cron/detect-stale-pieces.js

# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database (MySQL 8+) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=vitahub
DB_PASSWORD=vitahub_secret
DB_DATABASE=vitahub

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=vitahub_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ─────────────────────────────────────────
BCRYPT_ROUNDS=10

# ─── Throttle ───────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── File Storage ───────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# ─── Integrations: Meta ─────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_WEBHOOK_VERIFY_TOKEN=
META_TEST_EVENT_CODE=
META_CONVERSIONS_ACCESS_TOKEN=
API_PUBLIC_URL=https://api.example.com/api
# 32 bytes in base64 or 64 hexadecimal characters. Required in production.
INTEGRATION_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# ─── Integrations: Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
VITE_API_URL=/api

# ─── AI ─────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4

# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database (MySQL 8+) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=vitahub
DB_PASSWORD=vitahub_secret
DB_DATABASE=vitahub

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=vitahub_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ─────────────────────────────────────────
BCRYPT_ROUNDS=10

# ─── Throttle ───────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── File Storage ───────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# ─── Integrations: Meta ─────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# ─── Integrations: Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI ─────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4
